rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for personal data while providing 
     * shared access to educational curriculum content. The security posture is "private-by-default," 
     * where users can only access data explicitly associated with their unique identifier.
     *
     * DATA STRUCTURE
     * - /users/{userId}: Private user profiles and roots for user-specific data.
     * - /modules/{moduleId}: Global educational modules.
     * - /users/{userId}/drafts/{draftId}: Private strategic content.
     * - /users/{userId}/progress/{progressId}: Private tracking of learning milestones.
     *
     * KEY SECURITY DECISIONS
     * - Authentication: Private data access requires a verified identity.
     * - Public Access: The curriculum catalog (/modules) is publicly readable to allow browsing.
     * - Ownership: User-specific documents are validated against the URL path and auth token.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /drafts/{draftId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /progress/{moduleId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    /**
     * @description Rules for interactive learning modules. 
     * Catalog is publicly readable. Management requires authentication.
     */
    match /modules/{moduleId} {
      // Allow anyone to see the course catalog
      allow get, list: if true;
      
      // Allow signed-in users to manage modules for this prototype
      // In a production system, this would be restricted to admin UIDs
      allow create, update, delete: if isSignedIn();
    }
  }
}