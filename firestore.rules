/**
 * Firestore Security Rules for 'The Nicole Interface'
 *
 * Core Philosophy:
 * This ruleset implements a strict user-ownership model combined with an administrative 
 * content management system. Access is fundamentally governed by the user's identity 
 * and their position within the database hierarchy.
 *
 * Data Structure:
 * 1. User-Specific Data: All personal profiles, progress tracking, and AI-generated 
 *    outputs are nested under `/userProfiles/{userProfileId}/...`. 
 * 2. Curriculum Data: Learning modules and lessons are stored in global top-level 
 *    collections accessible by all authenticated users but managed by administrators.
 * 3. Role Management: Administrative privileges are determined by the existence of 
 *    a document in the `/roles_admin/` collection.
 *
 * Key Security Decisions:
 * - Authorization Independence: Rules rely on the document path (userProfileId) 
 *   to determine ownership, avoiding expensive `get()` calls to parent documents.
 * - Ownership Enforcement: Users can only read, list, or modify data within their 
 *   own user tree.
 * - Relational Integrity: On creation of user-owned documents, rules enforce that 
 *   internal 'userId' or 'id' fields match the path ID to prevent data-mismatch exploits.
 * - Restricted Writes: Global curriculum data (modules/lessons) is strictly read-only 
 *    for standard users.
 *
 * Denormalization for Authorization:
 * The data model leverages path-based ownership. By nesting progress and outputs 
 * directly under the UserProfile path, we eliminate the need for cross-collection 
 * lookups to verify who owns a specific revision or progress record.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is an owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Rules ---

    /**
     * @description Rules for user profile documents. Users manage their own profiles.
     * @path userProfiles/{userProfileId}
     * @allow (create) if auth.uid == userProfileId.
     * @deny (update) if auth.uid != userProfileId.
     * @principle Ownership and Self-Creation.
     */
    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId);
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update, delete: if isExistingOwner(userProfileId) && request.resource.data.id == resource.data.id;

      /**
       * @description Tracks individual user progress through curriculum modules.
       * @path userProfiles/{userProfileId}/moduleProgress/{progressId}
       * @allow (list) if auth.uid == userProfileId.
       * @deny (create) if data.userId does not match path userProfileId.
       * @principle Path-based ownership with relational integrity.
       */
      match /moduleProgress/{progressId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && request.resource.data.userId == userProfileId;
        allow update, delete: if isExistingOwner(userProfileId) && request.resource.data.userId == resource.data.userId;
      }

      /**
       * @description Strategic outputs (memos, proposals) owned by the user.
       * @path userProfiles/{userProfileId}/outputs/{outputId}
       * @allow (get) if auth.uid == userProfileId.
       * @deny (update) if attempting to change the owner (userId).
       * @principle Immutable ownership field.
       */
      match /outputs/{outputId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && request.resource.data.userId == userProfileId;
        allow update, delete: if isExistingOwner(userProfileId) && request.resource.data.userId == resource.data.userId;

        /**
         * @description Revisions of a specific output. Inherits ownership from path.
         * @path userProfiles/{userProfileId}/outputs/{outputId}/revisions/{revisionId}
         * @allow (create) if owner of the parent output path.
         * @deny (update) if document does not exist.
         * @principle Authorization independence through deep nesting.
         */
        match /revisions/{revisionId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId);
          allow update, delete: if isExistingOwner(userProfileId);
        }
      }
    }

    /**
     * @description Global curriculum modules.
     * @path modules/{moduleId}
     * @allow (get) if isSignedIn().
     * @deny (write) if user is not an admin.
     * @principle Public Read with Administrative Writes.
     */
    match /modules/{moduleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /**
       * @description Specific lessons within a module.
       * @path modules/{moduleId}/lessons/{lessonId}
       * @allow (list) if isSignedIn().
       * @deny (create) if user is not an admin.
       * @principle Inherited global access posture.
       */
      match /lessons/{lessonId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Collection used to define administrative roles.
     * @path roles_admin/{userProfileId}
     * @allow (get) if isSignedIn().
     * @deny (write) always (managed via admin console/backend).
     * @principle Database Access Control (DBAC).
     */
    match /roles_admin/{userProfileId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}