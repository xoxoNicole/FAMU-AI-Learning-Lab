
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the FAMU faculty member.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "title": { "type": "string", "description": "e.g., Dean, Professor" },
        "department": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Draft": {
      "title": "Strategic Draft",
      "description": "Content generated or refined in the AI Lab.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "Auto-generated or user-provided title." },
        "content": { "type": "string" },
        "type": { "type": "string", "description": "e.g., memo, proposal, email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "tone": { "type": "number", "description": "The tone slider value (0-100)." }
      },
      "required": ["title", "content", "createdAt"]
    },
    "ModuleProgress": {
      "title": "Module Progress",
      "description": "Tracking completion of learning modules.",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "completed": { "type": "boolean" },
        "lastAccessed": { "type": "string", "format": "date-time" }
      },
      "required": ["moduleId", "completed"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Root user profile document."
    },
    "/users/{userId}/drafts/{draftId}": {
      "schema": "#/backend/entities/Draft",
      "description": "Collection of strategic content saved by the user."
    },
    "/users/{userId}/progress/{moduleId}": {
      "schema": "#/backend/entities/ModuleProgress",
      "description": "Tracking progress for specific modules."
    }
  }
}
