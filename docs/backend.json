
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores profile information for authenticated users.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UID) for the user."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "faculty"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "email", "firstName", "lastName", "role", "createdAt"]
    },
    "LicenseConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LicenseConfig",
      "type": "object",
      "description": "Global configuration for application licensing.",
      "properties": {
        "totalLicenses": {
          "type": "number",
          "description": "Total number of faculty licenses provisioned."
        },
        "activeLicenses": {
          "type": "number",
          "description": "Number of licenses currently in use."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["totalLicenses", "activeLicenses", "updatedAt"]
    },
    "Feedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Feedback",
      "type": "object",
      "description": "User feedback on AI mentor responses.",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "isPositive": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "response", "isPositive", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "userProfiles/{userProfileId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles. Owners can read/write their own."
        }
      },
      {
        "path": "system/license",
        "definition": {
          "entityName": "LicenseConfig",
          "schema": { "$ref": "#/backend/entities/LicenseConfig" },
          "description": "Global license tracking. Publicly readable to check availability, admin writable."
        }
      },
      {
        "path": "modules/{moduleId}",
        "definition": {
          "entityName": "Module",
          "schema": { "$ref": "#/backend/entities/Module" },
          "description": "Learning modules catalog."
        }
      },
      {
        "path": "feedback/{feedbackId}",
        "definition": {
          "entityName": "Feedback",
          "schema": { "$ref": "#/backend/entities/Feedback" },
          "description": "Audit log for AI responses."
        }
      }
    ]
  }
}
